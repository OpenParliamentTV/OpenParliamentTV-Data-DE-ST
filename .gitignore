# Do not version converted/parsed media files (originals are raw-*/source formats)
original/media/[0-9]*-media.json
# Do not version converted/parsed proceeding files (originals are xml/html/jsonld/raw-*)
original/proceedings/[0-9]*-proceedings.json
# Per-speech raw media AJAX responses + transcript cache — both re-fetchable and
# would balloon the repo (~260 files/session). Regenerated by the scraper/merger;
# the platform input under processed/ is versioned instead.
original/media/[0-9]*/
original/proceedings/transcripts/
# Do not version cache directory
cache/

# Mac OS X
.DS_Store
.AppleDouble
.LSOverride

# Linux
.directory

# Logs
logs
_logs/
*.log

# Runtime data
pids
*.pid
*.seed
.idea/
__pycache__
*.lock

